# Gemini API configuration for the stable backend.
GEMINI_API_KEY=replace-with-your-gemini-api-key
BASE_URL=https://generativelanguage.googleapis.com/v1beta/
GEMINI_MODEL=gemini-3.5-flash
AI_SESSION_CALL_LIMIT=10
# Set this in deployed environments to keep signed quota cookies valid across restarts.
AI_SESSION_COOKIE_SECRET=replace-with-a-random-secret
