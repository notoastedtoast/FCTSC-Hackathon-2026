# Do not commit real credentials. GOOGLE_* names are preferred; GEMINI_* remain supported.
GOOGLE_API_KEY=replace-with-your-gemini-api-key
GOOGLE_MODEL=gemini-3.5-flash
GOOGLE_FALLBACK_MODEL=gemini-3.1-flash-lite
# Optional third provider.
# GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=openai/gpt-oss-20b
AI_SESSION_CALL_LIMIT=10

# Optional: omit DATABASE_URL to use the local SQLite file app.db.
# DATABASE_URL=sqlite:///app.db

# For a shared production deployment, use a Supabase transaction-pooler URL
# (normally port 6543). URL-encode special characters in the password and keep
# this value server-side only.
# DATABASE_URL=postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
