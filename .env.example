# Do not commit a real API key.
GEMINI_API_KEY=replace-with-your-gemini-api-key
# Optional; defaults to gemini-3.5-flash.
GEMINI_MODEL=gemini-3.5-flash
# Secondary Gemini target used after an HTTP failure, timeout, or invalid response.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# Optional third provider. Without this key, only the two Gemini targets are used.
# GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=openai/gpt-oss-20b
AI_SESSION_CALL_LIMIT=10

# Required: use Supabase's Transaction pooler URL (port 6543) on Vercel.
# Keep this server-side and replace [YOUR-PASSWORD] with the database password.
DATABASE_URL=postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
